# Parallel API key — required for monitors, enrichment, and deep research
PARALLEL_API_KEY=your_parallel_api_key_here

# Vercel Blob — stores per-facility enrichment data for the basis panel
# Set after creating a Blob store in Vercel Dashboard → Storage → Blob
ENRICHMENTS_BLOB_URL=https://your-store.private.blob.vercel-storage.com/enrichments.json
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Optional: password-protect the demo
SITE_PASSWORD=your_demo_password

# Optional: webhook URL for snapshot monitors (set to your deployed URL)
# WEBHOOK_URL=https://your-app.vercel.app/api/webhook
